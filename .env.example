# VERIFACT v2.0 - Environment Configuration Template

# Server Configuration
FLASK_ENV=development
PORT=5000
SECRET_KEY=verifact_super_secret_session_key_change_in_production
JWT_SECRET_KEY=verifact_jwt_secret_token_key_change_in_production

# Database Configuration
# Supported types: sqlite, mongodb, postgres
DATABASE_TYPE=sqlite
DATABASE_NAME=database.db

# If using mongodb
MONGO_URI=mongodb://localhost:27017/verifact

# If using postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verifact

# Real-time News API Keys
# Get keys from: https://newsapi.org/ and https://gnews.io/
NEWS_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# AI & NLP Configuration
# If true, attempts to load DistilBERT for predictions. If false, uses fast ML ensemble.
USE_TRANSFORMERS=false

# Conversational AI API Keys (Upgrade v2.5)
# Set GROQ_API_KEY to activate Llama-3 AI investigation chatbot
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

